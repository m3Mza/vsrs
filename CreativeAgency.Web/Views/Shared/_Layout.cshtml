<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="portfolio-layout">
        <header class="portfolio-header">
            <nav class="portfolio-nav">
                <div class="nav-left">
                    <a class="nav-link-minimal" asp-controller="Pocetna" asp-action="Pocetna">POČETNA</a>
                    <a class="nav-link-minimal" asp-controller="Projekti" asp-action="Pregled">PROJEKTI</a>
                </div>
                <div class="nav-right">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="nav-link-minimal">@User.Identity.Name</span>
                        <form asp-controller="Nalog" asp-action="Odjava" method="post" class="d-inline">
                            <button type="submit" class="nav-link-minimal nav-button">ODJAVA</button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link-minimal" asp-controller="Nalog" asp-action="Prijava">PRIJAVA</a>

                    }
                </div>
            </nav>
        </header>
        
        <main class="portfolio-main">
            @if (TempData["PorukaUspeha"] != null)
            {
                <div class="alert-minimal alert-success">
                    @TempData["PorukaUspeha"]
                </div>
            }
            @if (TempData["PorukaGreske"] != null)
            {
                <div class="alert-minimal alert-danger">
                    @TempData["PorukaGreske"]
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/scramble-hover.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
