@{
    ViewData["Title"] = "Error";
}

<div class="text-center">
    <h1 class="text-danger">Error</h1>
    <h2 class="text-danger">An error occurred while processing your request.</h2>
    
    @if (ViewData["ShowRequestId"] != null && ViewData["ShowRequestId"] is bool && (bool)ViewData["ShowRequestId"])
    {
        <p>
            <strong>Request ID:</strong> <code>@ViewData["RequestId"]</code>
        </p>
    }

    <hr />
    
    <h3>What can you do?</h3>
    <ul class="list-unstyled">
        <li><a asp-controller="Home" asp-action="Index">Go to Home Page</a></li>
        <li><a href="javascript:history.back()">Go Back</a></li>
    </ul>
</div>
