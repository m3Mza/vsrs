@model KreirajProjekatViewModel
@{
    ViewData["Title"] = "Uredi projekat";
    var projekatId = ViewData["ProjekatId"];
}

<div class="form-container">
    <h1 class="form-title">Uredi projekat</h1>
    
    <form asp-action="Uredi" asp-route-id="@projekatId" method="post" class="minimal-form">
        <div asp-validation-summary="All" class="error-text mb-3"></div>
        
        <div class="form-group-modern">
            <label asp-for="Naziv">Naziv projekta</label>
            <input asp-for="Naziv" class="form-input-modern" />
            <span asp-validation-for="Naziv" class="error-text"></span>
        </div>
        
        <div class="form-group-modern">
            <label asp-for="Opis">Opis</label>
            <textarea asp-for="Opis" class="form-input-modern" rows="4"></textarea>
            <span asp-validation-for="Opis" class="error-text"></span>
        </div>
        
        <div class="form-group-modern">
            <label asp-for="Status">Status</label>
            <select asp-for="Status" class="form-input-modern">
                <option value="Aktivan">Aktivan</option>
                <option value="NaCekanju">Na Čekanju</option>
                <option value="Zavrsen">Završen</option>
            </select>
            <span asp-validation-for="Status" class="error-text"></span>
        </div>
        
        <div class="form-group-modern">
            <label asp-for="Kategorija">Kategorija</label>
            <select asp-for="Kategorija" class="form-input-modern">
                <option value="Sajt">Sajt</option>
                <option value="Aplikacija">Aplikacija</option>
                <option value="Logo">Logo</option>
                <option value="Brending">Brending</option>
                <option value="Identitet">Identitet</option>
                <option value="Foto/Video">Foto/Video</option>
            </select>
            <span asp-validation-for="Kategorija" class="error-text"></span>
        </div>
        
        <div class="form-group-modern">
            <label asp-for="DatumPocetka">Datum početka</label>
            <input asp-for="DatumPocetka" class="form-input-modern" type="date" />
            <span asp-validation-for="DatumPocetka" class="error-text"></span>
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Sačuvaj izmene</button>
            <a asp-action="Detalji" asp-route-id="@projekatId" class="btn-text">Otkaži</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
