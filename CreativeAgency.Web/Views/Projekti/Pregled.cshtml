@using System.Security.Claims
@model ListaProjekataViewModel
@{
    ViewData["Title"] = "Projekti";
    var currentUserId = User.Identity?.IsAuthenticated == true 
        ? int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0") 
        : (int?)null;
}

<div class="portfolio-header-actions">
    @if (Model.MozeUredjivati)
    {
        <a asp-action="Kreiraj" class="btn btn-success">+ Novi projekat</a>
    }
</div>

@if (!Model.Projekti.Any())
{
    <div class="empty-state">
        <p>Nema projekata. @(Model.MozeUredjivati ? "Kreirajte prvi projekat." : "")</p>
    </div>
}
else
{
    <div class="portfolio-table">
        <div class="portfolio-header-row">
            <div class="col-name"><small><u>Naziv projekta</u></small></div>
            <div class="col-category"><small><u>Status</u></small></div>
            <div class="col-client"><small><u>Tip</u></small></div>
            <div class="col-year"><small><u>Datum završetka</u></small></div>
        </div>
        @foreach (var projekat in Model.Projekti)
        {
            <div class="portfolio-row" data-project-id="@projekat.ProjekatId">
                <div class="row-main" onclick="toggleRow(this)">
                    <div class="col-name">@projekat.Naziv</div>
                    <div class="col-category">
                        <span class="status-badge status-@projekat.Status.ToLower()">@projekat.Status</span>
                    </div>
                    <div class="col-client">@projekat.Kategorija</div>
                    <div class="col-year">
                        @if (projekat.Status == "Zavrsen" && projekat.DatumZavrsetka.HasValue)
                        {
                            @projekat.DatumZavrsetka.Value.ToString("dd.MM.yyyy")
                        }
                        else
                        {
                            <text>U toku</text>
                        }
                    </div>
                </div>
                <div class="row-expanded">
                    <div class="expanded-content">
                        <p class="description">@(projekat.Opis ?? "Nema opisa")</p>
                        @{
                            var isOwner = currentUserId.HasValue && projekat.KreiraoKorisnikId == currentUserId.Value;
                        }
                        @if (Model.MozeUredjivati || isOwner)
                        {
                            <div class="expanded-actions">
                                <a asp-action="Detalji" asp-route-id="@projekat.ProjekatId" class="btn-text">Detalji</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
function toggleRow(element) {
    const row = element.closest('.portfolio-row');
    const expanded = row.querySelector('.row-expanded');
    const isOpen = row.classList.contains('open');
    
    // Close all other rows
    document.querySelectorAll('.portfolio-row.open').forEach(r => {
        if (r !== row) {
            r.classList.remove('open');
        }
    });
    
    // Toggle current row
    row.classList.toggle('open');
}
</script>
