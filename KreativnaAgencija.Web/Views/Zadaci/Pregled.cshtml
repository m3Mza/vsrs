@model ListaZadatakaViewModel
@{
    ViewData["Title"] = Model.ProjekatId.HasValue ? $"Zadaci - {Model.NazivProjekta}" : "Zadaci";
}

<div class="portfolio-header-actions">
    <a asp-action="Kreiraj" asp-route-projekatId="@Model.ProjekatId" class="btn btn-success">+ Novi zadatak</a>
    @if (Model.ProjekatId.HasValue)
    {
        <a asp-controller="Projekti" asp-action="Detalji" asp-route-id="@Model.ProjekatId" class="btn-text">Nazad na projekat</a>
    }
</div>

@if (!Model.Zadaci.Any())
{
    <div class="empty-state">
        <p>Nema zadataka. Kreirajte prvi zadatak.</p>
    </div>
}
else
{
    <div class="portfolio-table">
        <div class="portfolio-header-row">
            <div class="col-name"><small><u>Naziv zadatka</u></small></div>
            <div class="col-category"><small><u>@(!Model.ProjekatId.HasValue ? "Projekat" : "Status")</u></small></div>
            <div class="col-client"><small><u>Dodeljen</u></small></div>
            <div class="col-year"><small><u>Rok izvršenja</u></small></div>
        </div>
        @foreach (var zadatak in Model.Zadaci)
        {
            <div class="portfolio-row" data-task-id="@zadatak.ZadatakId">
                <div class="row-main" onclick="toggleRow(this)">
                    <div class="col-name">@zadatak.Naslov</div>
                    <div class="col-category">@(!Model.ProjekatId.HasValue ? zadatak.Projekat.Naziv : zadatak.Status)</div>
                    <div class="col-client">@(zadatak.Dodeljen?.KorisnickoIme ?? "Nedodeljen")</div>
                    <div class="col-year">@(zadatak.RokIzvrsenja?.Year.ToString() ?? "N/A")</div>
                </div>
                <div class="row-expanded">
                    <div class="expanded-content">
                        <p class="description">@(zadatak.Opis ?? "Nema opisa")</p>
                        <div class="task-meta">
                            <span class="meta-item">Status: <strong>@zadatak.Status</strong></span>
                            <span class="meta-item">Prioritet: <strong>@zadatak.Prioritet</strong></span>
                            @if (zadatak.RokIzvrsenja.HasValue)
                            {
                                <span class="meta-item">Rok: <strong>@zadatak.RokIzvrsenja.Value.ToString("dd.MM.yyyy")</strong></span>
                            }
                        </div>
                        <div class="expanded-actions">
                            <a asp-action="Uredi" asp-route-id="@zadatak.ZadatakId" class="btn-text">Uredi</a>
                            <form asp-action="Obrisi" asp-route-id="@zadatak.ZadatakId" method="post" class="d-inline" onsubmit="return confirm('Da li ste sigurni?');">
                                <button type="submit" class="btn-text btn-delete">Obriši</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
function toggleRow(element) {
    const row = element.closest('.portfolio-row');
    const expanded = row.querySelector('.row-expanded');
    const isOpen = row.classList.contains('open');
    
    // Close all other rows
    document.querySelectorAll('.portfolio-row.open').forEach(r => {
        if (r !== row) {
            r.classList.remove('open');
        }
    });
    
    // Toggle current row
    row.classList.toggle('open');
}
</script>
