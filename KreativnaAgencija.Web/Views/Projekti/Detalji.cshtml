@using System.Security.Claims
@model DetaljiProjektaViewModel
@{
    ViewData["Title"] = Model.Projekat.Naziv;
    var currentUserId = User.Identity?.IsAuthenticated == true 
        ? int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0") 
        : (int?)null;
}

<div class="project-details">
    <div class="project-header">
        <div class="project-title-section">
            <h1 class="project-title">@Model.Projekat.Naziv</h1>
        </div>
        <div class="project-actions">
            @if (Model.MozeUredjivati)
            {
                <a asp-controller="Zadaci" asp-action="Kreiraj" asp-route-projekatId="@Model.Projekat.ProjekatId" class="btn btn-success">+ Dodaj zadatak</a>
                <a asp-action="Uredi" asp-route-id="@Model.Projekat.ProjekatId" class="btn-text">Uredi projekat</a>
                <form asp-action="Obrisi" asp-route-id="@Model.Projekat.ProjekatId" method="post" class="d-inline" onsubmit="return confirm('Da li ste sigurni da želite da obrišete ovaj projekat?');">
                    <button type="submit" class="btn-text btn-delete">Obriši</button>
                </form>
            }
            <a asp-action="Pregled" class="btn-text">Nazad na listu</a>
        </div>
    </div>

    <div class="project-info">
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Status:</span>
                <span class="status-badge status-@Model.Projekat.Status.ToLower()">@Model.Projekat.Status</span>
            </div>
            <div class="info-item">
                <span class="info-label">Datum početka:</span>
                <span>@Model.Projekat.DatumPocetka.ToString("dd.MM.yyyy")</span>
            </div>
            @if (Model.Projekat.DatumZavrsetka.HasValue)
            {
                <div class="info-item">
                    <span class="info-label">Datum završetka:</span>
                    <span>@Model.Projekat.DatumZavrsetka.Value.ToString("dd.MM.yyyy")</span>
                </div>
            }
            <div class="info-item">
                <span class="info-label">Kreiran:</span>
                <span>@Model.Projekat.DatumKreiranja.ToString("dd.MM.yyyy")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Ukupno zadataka:</span>
                <span>@Model.Zadaci.Count()</span>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.Projekat.Opis))
        {
            <div class="project-description">
                <span class="info-label">Opis:</span>
                <p>@Model.Projekat.Opis</p>
            </div>
        }
    </div>

    <h2 class="section-title">Zadaci</h2>
    @if (!Model.Zadaci.Any())
    {
        <div class="empty-state">
            <p>Još nema zadataka. @(Model.MozeUredjivati ? "Dodajte vaš prvi zadatak!" : "")</p>
        </div>
    }
    else
    {
        <div class="portfolio-table">
            <div class="portfolio-header-row task-row">
                <div class="col-name"><small><u>Naziv zadatka</u></small></div>
                <div class="col-category"><small><u>Status</u></small></div>
                <div class="col-client"><small><u>Dodeljen</u></small></div>
                <div class="col-year"><small><u>Rok izvršenja</u></small></div>
            </div>
            @foreach (var zadatak in Model.Zadaci)
            {
                var canEditTask = Model.MozeUredjivati || (currentUserId.HasValue && zadatak.DodeljenKorisnikId == currentUserId.Value);
                
                <div class="portfolio-row" data-task-id="@zadatak.ZadatakId">
                    <div class="row-main task-row">
                        <div class="col-name">@zadatak.Naslov</div>
                        <div class="col-category"><span class="status-badge status-@zadatak.Status.ToLower()">@zadatak.Status</span></div>
                        <div class="col-client">@(zadatak.Dodeljen?.KorisnickoIme ?? "Nedodeljen")</div>
                        <div class="col-year">@(zadatak.RokIzvrsenja?.ToString("dd.MM.yyyy") ?? "N/A")</div>
                    </div>
                    @if (canEditTask)
                    {
                        <div class="task-actions">
                            <a asp-controller="Zadaci" asp-action="Uredi" asp-route-id="@zadatak.ZadatakId" class="btn-text">Uredi</a>
                            @if (Model.MozeUredjivati)
                            {
                                <form asp-controller="Zadaci" asp-action="Obrisi" asp-route-id="@zadatak.ZadatakId" method="post" class="d-inline" onsubmit="return confirm('Da li ste sigurni?');">
                                    <button type="submit" class="btn-text btn-delete">Obriši</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
